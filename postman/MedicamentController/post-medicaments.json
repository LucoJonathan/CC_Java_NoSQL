{
  "info": {
    "name": "MedicamentController - POST /api/medicaments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /api/medicaments",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"MED001\",\n  \"libelle\": \"Aspirine 500mg\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/medicaments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "medicaments"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ]
}
