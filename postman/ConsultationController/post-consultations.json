{
  "info": {
    "name": "ConsultationController - POST /api/consultations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /api/consultations",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"numeroConsultation\": \"CONS001\",\n  \"date\": \"2026-07-07T10:30:00\",\n  \"patientNumeroSS\": \"123456789012\",\n  \"medecinMatricule\": \"DOC001\",\n  \"prescriptions\": []\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/consultations",
          "host": ["{{baseUrl}}"],
          "path": ["api", "consultations"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ]
}
