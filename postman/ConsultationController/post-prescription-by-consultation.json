{
  "info": {
    "name": "ConsultationController - POST /api/consultations/{numeroConsultation}/prescriptions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /api/consultations/{{numeroConsultation}}/prescriptions",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"codeMedicament\": \"MED001\",\n  \"nbPrise\": 3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/consultations/{{numeroConsultation}}/prescriptions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "consultations", "{{numeroConsultation}}", "prescriptions"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "numeroConsultation", "value": "CONS001" }
  ]
}
