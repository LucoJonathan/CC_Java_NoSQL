{
  "info": {
    "name": "PatientController - DELETE /api/patients/{numeroSS}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "DELETE /api/patients/{{numeroSS}}",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/patients/{{numeroSS}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "patients", "{{numeroSS}}"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "numeroSS", "value": "123456789012" }
  ]
}
