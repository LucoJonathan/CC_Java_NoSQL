{
  "info": {
    "name": "MedecinController - DELETE /api/medecins/{matricule}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "DELETE /api/medecins/{{matricule}}",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/medecins/{{matricule}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "medecins", "{{matricule}}"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "matricule", "value": "DOC001" }
  ]
}
